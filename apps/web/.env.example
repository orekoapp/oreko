# ===========================================
# QuoteCraft Web App Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuoteCraft

# Database (PostgreSQL)
DATABASE_URL="postgresql://quotecraft:quotecraft@localhost:5432/quotecraft?schema=public"

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Generate with: openssl rand -base64 32

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email — choose one provider
# Option 1: Resend (recommended)
RESEND_API_KEY=
EMAIL_FROM=noreply@quotecraft.dev
EMAIL_REPLY_TO=

# Option 2: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# File Storage
STORAGE_PROVIDER=local          # local | s3 | r2
STORAGE_LOCAL_PATH=./uploads
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_URL=

# Stripe (public key for client-side checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Demo Mode (optional)
DEMO_USER_EMAIL=

# Cron Jobs (optional — secret for /api/cron endpoints)
CRON_SECRET=

# PDF Generation (optional — Puppeteer path override)
# PUPPETEER_EXECUTABLE_PATH=

# Social Links (optional — shown in landing page footer)
# NEXT_PUBLIC_GITHUB_URL=https://github.com/WisdmLabs/quote-software
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_DISCORD_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
