{
  "name": "oreko",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source quote and invoice tool for freelancers and small businesses",
  "repository": {
    "type": "git",
    "url": "https://github.com/orekoapp/oreko.git"
  },
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @oreko/database generate",
    "db:push": "pnpm --filter @oreko/database push",
    "db:migrate": "pnpm --filter @oreko/database migrate",
    "db:studio": "pnpm --filter @oreko/database studio",
    "db:seed": "pnpm --filter @oreko/database seed",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.19.0",
    "turbo": "^2.9.5",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "isomorphic-dompurify": "^3.8.0"
  }
}
