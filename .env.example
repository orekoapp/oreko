# ===========================================
# QuoteCraft Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# [Required] = must be set for the app to work
# [Optional] = app works without it, enables extra features

# Application [Required]
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuoteCraft

# Database (PostgreSQL) [Required]
DATABASE_URL="postgresql://quotecraft:quotecraft@localhost:5432/quotecraft?schema=public"

# Redis (for sessions and caching) [Required]
# For password-protected Redis, use: redis://:yourpassword@localhost:6379
REDIS_URL="redis://localhost:6379"

# Authentication (NextAuth.js) [Required]
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Generate with: openssl rand -base64 32

# OAuth Providers [Optional] — only needed if you want Google/GitHub login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe [Optional] — only needed for payment features
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend) [Optional] — only needed for sending emails
RESEND_API_KEY=
EMAIL_FROM="QuoteCraft <noreply@quote.persuado.tech>"
EMAIL_REPLY_TO=

# File Storage [Optional] — defaults to local storage
# Options: 'local', 's3', or 'cloudflare'
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=/uploads

# S3/Cloudflare R2 Storage [Optional] — only if STORAGE_PROVIDER=s3 or cloudflare
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT= # Required for Cloudflare R2

# PDF Generation [Optional]
# Puppeteer settings for PDF generation
PUPPETEER_EXECUTABLE_PATH= # Optional, path to Chrome/Chromium

# Rate Limiting [Optional] — has sensible defaults
RATE_LIMIT_WINDOW=60000 # 1 minute in ms
RATE_LIMIT_MAX_REQUESTS=100

# Logging [Optional]
LOG_LEVEL=debug # debug, info, warn, error
