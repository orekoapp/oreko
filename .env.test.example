# ===========================================
# Oreko Test Environment Variables
# ===========================================
# Copy this file to .env.test and fill in values for running tests.
# Tests use a separate database to avoid corrupting development data.

# Application
NODE_ENV=test
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Oreko

# Test Database (separate from development!)
DATABASE_URL="postgresql://oreko:oreko@localhost:5432/oreko_test?schema=public"

# Redis (use a separate DB index for tests)
REDIS_URL="redis://localhost:6379/1"

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-do-not-use-in-production

# Stripe (use test mode keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Email (disabled in tests — use mock)
RESEND_API_KEY=
EMAIL_FROM="Oreko Test <test@localhost>"

# File Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./test-uploads
STORAGE_PUBLIC_URL=/uploads

# Rate Limiting (relaxed for tests)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=warn
